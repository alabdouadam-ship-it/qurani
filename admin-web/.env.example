NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-publishable-anon-key>
NEXT_PUBLIC_ADMIN_EMAIL_DOMAIN=qurani.info

# Service-role key — ONLY used by the local scripts in ./scripts (admin
# management). It bypasses Row Level Security, so keep it secret: never commit
# it, never expose it to the browser/Next.js public env. Not required to run
# the dashboard itself. Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
